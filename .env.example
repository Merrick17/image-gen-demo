# ── Base model ────────────────────────────────────────────────────────────────
# Full SDXL (~7 GB, best quality):  stabilityai/stable-diffusion-xl-base-1.0
# Lighter SDXL-compatible (~3 GB):  segmind/SSD-1B
MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0

# ── LCM fast inference ────────────────────────────────────────────────────────
# Cuts steps from 20-30 down to 4 — essential for CPU inference speed
USE_LCM=true
LCM_LORA_PATH=models/lcm_lora.safetensors
NUM_STEPS=4
GUIDANCE_SCALE=1.5    # LCM needs low guidance (1.0–2.0). Use 7.5 when LCM is off.

# ── Style LoRA ────────────────────────────────────────────────────────────────
# Pick one from models/ (downloaded by init-loras on first run):
#   models/photography.safetensors        → photorealistic slider (ostris)
#   models/fashion_avantgarde.safetensors → avant-garde editorial (KappaNeuro)
#   models/fashion_selfie.safetensors     → selfie/street photography
#   models/fashion_weird.safetensors      → editorial weird outfits (Norod78)
#   models/dmd2_fast.safetensors          → DMD2 4-step alternative speed LoRA
LORA_PATH=models/photography.safetensors
LORA_SCALE=0.8

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...          # required for gated models
# HF_HUB_CACHE=/app/models/hf_cache
